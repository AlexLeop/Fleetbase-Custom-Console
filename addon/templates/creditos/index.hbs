<Layout::Section::Body class="overflow-y-scroll h-full">
    <div class="p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold text-white">Créditos</h2>
        </div>

        <div class="bg-gray-800 rounded-lg">
            {{#if this.credits.length}}
                <table class="w-full text-sm text-left text-gray-300">
                    <thead class="text-xs text-gray-400 uppercase border-b border-gray-700">
                        <tr>
                            <th class="px-4 py-3">Data</th>
                            <th class="px-4 py-3">Motoboy</th>
                            <th class="px-4 py-3">Valor</th>
                            <th class="px-4 py-3">Motivo</th>
                            <th class="px-4 py-3">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each this.credits as |credit|}}
                            <tr class="border-b border-gray-700 hover:bg-gray-750">
                                <td class="px-4 py-3">{{credit.date}}</td>
                                <td class="px-4 py-3">{{credit.driver_name}}</td>
                                <td class="px-4 py-3 font-mono text-green-400">R$ {{credit.amount}}</td>
                                <td class="px-4 py-3">{{credit.reason}}</td>
                                <td class="px-4 py-3">
                                    <span class="px-2 py-1 rounded text-xs font-medium {{if (eq credit.status "approved") "bg-green-900 text-green-300" "bg-yellow-900 text-yellow-300"}}">
                                        {{credit.status}}
                                    </span>
                                </td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            {{else}}
                <p class="text-gray-500 text-center py-8">Nenhum crédito encontrado.</p>
            {{/if}}
        </div>
    </div>
</Layout::Section::Body>

<EmberWormhole @to="sidebar-menu-items">
    <Layout::Sidebar::Item @route="console.financeiro.home" @icon="chart-simple">Dashboard</Layout::Sidebar::Item>

    <Layout::Sidebar::Panel @open={{true}} @title="Operações">
        <Layout::Sidebar::Item @route="console.financeiro.escalas.index" @icon="calendar-alt">Escalas</Layout::Sidebar::Item>
        <Layout::Sidebar::Item @route="console.financeiro.lancamentos.index" @icon="file-invoice-dollar">Lançamentos</Layout::Sidebar::Item>
    </Layout::Sidebar::Panel>

    <Layout::Sidebar::Panel @open={{true}} @title="Financeiro">
        <Layout::Sidebar::Item @route="console.financeiro.calculo.index" @icon="calculator">Cálculo Semanal</Layout::Sidebar::Item>
        <Layout::Sidebar::Item @route="console.financeiro.creditos.index" @icon="hand-holding-usd">Créditos</Layout::Sidebar::Item>
    </Layout::Sidebar::Panel>

    <Layout::Sidebar::Panel @open={{true}} @title="Configurações">
        <Layout::Sidebar::Item @route="console.financeiro.taxas.index" @icon="percentage">Taxas</Layout::Sidebar::Item>
    </Layout::Sidebar::Panel>
</EmberWormhole>
<Layout::Section::Container>
    {{outlet}}
</Layout::Section::Container>

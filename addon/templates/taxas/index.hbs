<Layout::Section::Body class="overflow-y-scroll h-full">
    <div class="p-6">
        <h2 class="text-xl font-semibold text-white mb-6">Configuração de Taxas</h2>

        <div class="bg-gray-800 rounded-lg p-4">
            {{#if this.rates.length}}
                {{#each this.rates as |rate|}}
                    <div class="flex items-center justify-between p-3 border-b border-gray-700 last:border-0">
                        <div>
                            <div class="font-medium text-white">{{rate.name}}</div>
                            <div class="text-sm text-gray-400">{{rate.description}}</div>
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="number" value={{rate.value}} step="0.01" class="w-32 text-right bg-gray-700 border border-gray-600 text-white rounded px-3 py-2" {{on "change" (fn this.updateRate rate)}} />
                            <span class="text-sm text-gray-400">{{rate.unit}}</span>
                        </div>
                    </div>
                {{/each}}
                <div class="flex justify-end p-4">
                    <button type="button" class="bg-blue-600 hover:bg-blue-700 text-white font-medium rounded px-4 py-2 transition-colors" {{on "click" this.saveRates}}>
                        Salvar Taxas
                    </button>
                </div>
            {{else}}
                <p class="text-gray-500 text-center py-8">Nenhuma taxa configurada.</p>
            {{/if}}
        </div>
    </div>
</Layout::Section::Body>

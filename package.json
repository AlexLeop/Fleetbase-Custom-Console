{
    "name": "@fleetbase/financeiro-engine",
    "version": "0.1.0",
    "description": "Gestão Financeira de Motoboys – Extensão Expresso Neves para Fleetbase",
    "keywords": [
        "fleetbase-extension",
        "financeiro",
        "motoboys",
        "gestão financeira",
        "expresso neves",
        "ember-addon",
        "ember-engine"
    ],
    "fleetbase": {
        "route": "financeiro"
    },
    "repository": "",
    "license": "MIT",
    "author": "Expresso Neves",
    "directories": {
